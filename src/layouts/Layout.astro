---
export interface Props {
	title: string;
}

const { title } = Astro.props;
import Card from '../components/Card.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="The personal website of Cameron MacDonald, a front-end developer, UX designer, and accessibility specialist.">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="theme-color" content="#000000">
		<meta name="color-scheme" content="light dark">
		<meta name="author" content="Cameron MacDonald">
		<meta name="application-name" content="Personal website of Cameron MacDonald">
		<meta name="AdsBot-Google" content="noindex">
		<meta name="twitter:title" content="Cameron MacDonald">
		<meta name="twitter:image" content="https://cdmacdonald.com/cdmacdonald-favicon.png">
		<meta name="twitter:card" content="summary_large_image">
		<link rel="canonical" href="http://cdmacdonald.com">
		<link rel="icon" type="image/svg+xml" href="/cdmacdonald-favicon.png" />
		<link rel="preconnect" href="https://rsms.me/">
		<link rel="stylesheet" href="https://rsms.me/inter/inter.css">
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<h1>
				Cameron MacDonald
			</h1>
			<p><span class="prof-title">Design Technologist.</span> <span class="prof-title">Accessibilty Specialist.</span> <span class="prof-title">Angry Idealist.</span></p>
		</header>
		<main>
			<div id="about-section">
				<p>I'm a <span class="u-textBold">web developer</span>, <span class="u-textBold">user experience designer</span>, <span class="u-textBold">accessibility specialist</span>, and more.</p>
				<p>I specialize in <span class="u-textBold">design systems</span>. I currently work as a <span class="u-textBold">Design Technologist</span> for the Design Operations team at Ameriprise Financial.</p>
				<hr>
				<p>I like to spend my free time <span class="u-textBold">learning</span>.</p>
				<p class="u-textBold">I'm currently learning about:</p>
				<ul>
					<li>Abstract Syntax Trees (AST)</li>
					<li>Web Extension Development</li>
					<li>Rust (language)</li>
					<li>Web Components</li>
					<li>React Native</li>
					<li>Flutter</li>
					<li>Blender (3D)</li>
				</ul>
				<details>
					<summary class="u-textBold">
						Projects
						<span class="material-symbols-rounded" aria-hidden="true">expand_more</span>
					</summary>
					<dl>
						<dt><a href="https://github.com/cadomac/Proton-To-KeePass">Proton To KeePass</a></dt>
						<dd>A Python script that converts Proton Pass encrypted exports (.pgp) directly into KeePass databases without writing any decrypted passwords to the filesystem. Useful for secure backups in alternative software.</dd>
						<dt><a href="https://github.com/cadomac/fresh-eyes">Fresh Eyes</a></dt>
						<dd>A Chrome extension that applies a filter to webpages to attempt to correct colors and increase contrast for users with color vision deficiencies, such as myself. (I'm a moderate protan.)</dd>
						<dt><a href="https://www.printables.com/@cadomac_1434444">3D Printing Work (Printables.com)</a></dt>
						<dd>I like to make models and share them with others. My most popular model right now is a tenting leg I designed for my keyboard, the <a href="https://www.zsa.io/voyager/">ZSA Voyager</a>.</dd>
					</dl>
				</details>
			</div>
			<div class="LinkCardWrapper">
				<Card 
					href="https://github.com/cadomac" 
					title="GitHub" highlightColor="#7f44c4" 
					background={{
						light: "/logos/gh-mark.svg",
						dark: "/logos/gh-mark-white.svg"
					}} />
				<Card 
					href="https://gitlab.com/cadoma" 
					title="GitLab" highlightColor="#c34d00" 
					background={{
						light: "/logos/gitlab-logo-600.svg",
						dark: "/logos/gitlab-logo-700.svg"	
					}} />
				<Card 
					href="https://codepen.io/cadomac" 
					title="CodePen" highlightColor="#897000" 
					background={{
						light: "/logos/codepen-logo-black.png",
						dark: "/logos/codepen-logo-white.png"
					}} />
				<Card 
					href="https://www.behance.net/cadoma" 
					title="Behance" highlightColor="#024cff" 
					background={{
						light: "/logos/behance-square-logo.png",
						dark: "/logos/behance-square-logo-white.png"
					}} />
			</div>
		</main>
		<footer>
			<div class="social-banner">
				<a href="https://www.linkedin.com/in/macdonaldcameron" target="_blank" id="linkedin" aria-label="LinkedIn, opens in new tab" class="social-link">
					<picture>
						<source srcset="/logos/LI-In-white.png" media="(prefers-color-scheme: dark)" />
						<img src="/logos/LI-In-black.png" alt="" />
					</picture>
				</a>
				<a href="https://mastodon.social/@cadomac" target="_blank" aria-label="Mastodon, opens in new tab" id="mastodon" class="social-link">
					<picture>
						<source srcset="/logos/mastodon-logo-white.svg" media="(prefers-color-scheme: dark)" />
						<img src="/logos/mastodon-logo-black.svg" alt="" />
					</picture>
				</a>
			</div>
		</footer>
	</body>
</html>
<style lang="scss" is:global>
	@use "../styles/animations" as *;
	@use "../styles/colors" as *;
	@use "../styles/breakpoints" as *;
	@use "../styles/utils" as *;
	@use "sass:color";

	$gray-lt: color.adjust($gray-ash, $lightness: 25%);
	$black-eerie-dk: color.adjust($black-eerie, $lightness: -10%);
	:root { font-family: 'Inter', sans-serif; }
	@supports (font-variation-settings: normal) {
		:root { font-family: 'Inter var', sans-serif; }
	}

	$max-width: 1280px;
	html {
		background-color: $white;
		color: $black-eerie;

		@media (prefers-color-scheme: dark) {
			background-color: $black-eerie-dk;
			color: $white;
		}

		*::selection {
			background: $orange;

			@media (prefers-color-scheme: dark) {
				background: color.adjust($action, $lightness: -10%);
			}
		}

		*:focus,
		*:focus-visible {
			border-radius: 5px;
			outline: 5px solid $black-eerie;
			outline-offset: 3px;

			@media (prefers-color-scheme: dark) {
				outline-color: $white;
			}
		}

		hr {
			border: 1px solid color.adjust($gray-ash, $lightness: 18%);
			border-radius: 5px;
		}

		a {
			color: $orange;

			&:visited {
				color: color.adjust($orange, $lightness: -20%);
			}

			&:hover {
				color: color.adjust($orange, $lightness: -10%);
			}

			&:focus,
			&:focus-visible {
				border-radius: 1px;
			}
		}
	}
	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
	}
	code {
		font-family: Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
			Bitstream Vera Sans Mono, Courier New, monospace;
	}
	header {
		h1 {
			font-size: 4rem;
			font-weight: 800;
			margin: 0;

			@include sm {
				font-size: 2.5rem;
			}
		}

		p {
			font-size: 1.5rem;
			font-weight: bold;
			margin-top: 5px;

			@include sm {
				font-size: 1.25rem;
			}
		}
	}

	#about-section {
		background-color: $gray-lt;
		border-radius: 10px;
		margin: 20px 0;
		padding: 30px 40px 40px 40px;

		@media (prefers-color-scheme: dark) {
			background-color: $black-eerie;
		}

		details {
			& > summary {
				border-radius: 5px;
				cursor: pointer;
				color: $action;
				display: flex;
				font-size: 1.25rem;
				align-items: center;
				gap: 5px;
				margin-left: -10px;
				padding: 2px 2px 2px 10px;
				width: fit-content;

				&:hover {
					background-color: color.adjust($action, $alpha: -0.9);
				}

				@media (prefers-color-scheme: dark) {
					color: color.adjust($action, $lightness: 30%);

					&:hover {
						background-color: color.adjust($action, $alpha: -0.6);
					}
				}

				& span.material-symbols-rounded {
					font-size: 2rem;
					margin-top: 2px;
					transition: 0.2s ease;
				}
			}

			&[open] {
				span.material-symbols-rounded {
					transform: rotate(180deg);
				}
			}
		}

		h2 {
			margin: 5px 0;
		}

		p {
			font-size: 1.25rem;
		}

		dl {
			margin-left: 23px;
		}

		dt {
			font-weight: bold;
			margin-bottom: 10px;
		}

		dd {
			margin-bottom: 20px;
		}
	}

	.sectionHeader {
		font-size: 3rem;
		font-weight: bold;
		margin-top: 50px;

		@include sm {
			margin-bottom: 0;
			text-align: center;
		}
	}
	
	header {
		margin-left: auto;
		margin-right: auto;
		padding: 40px 40px 10px 40px;
		max-width: $max-width;
	}
	main {
		margin-left: auto;
		margin-right: auto;
		padding: 10px 40px 40px 40px;
		max-width: $max-width;
	}

	footer {
		margin-top: auto;
		width: 100%;
		background-color: color.adjust($white, $lightness: -3%);

		@media (prefers-color-scheme: dark) {
			background-color: color.adjust($black-eerie-dk, $lightness: -3%);
		}
	}

	.prof-title {
		@include sm {
			display: block;
		}
	}

	.social-banner {
		display: flex;
		gap: 20px;
		max-width: $max-width;
		margin: auto;
		padding: 20px 40px;

		@include sm {
			justify-content: center;
		}
	}

	#linkedin {
		@include diagonalColorSwipe(#5ab0f7);
	}

	#mastodon {
		@include diagonalColorSwipe(#5b4adf);
	}

	.social-link {
		display: inline-block;
		position: relative;
		width: 50px;
		height: 50px;
		border-radius: 7px;
		&:focus, &:active {
			outline-width: 3px;
		}

		& img {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: 80%;
		};
	}
	.LinkCardWrapper {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 20px;
		margin-top: 30px;
	}
</style>
