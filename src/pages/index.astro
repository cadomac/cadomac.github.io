---
import Layout from '../layouts/Layout.astro';

const links = [
  {
    name: "Resume",
    url: "/resume", 
    blurb: "experience"
  },
  {
    name: "Work",
    url: "/work",
    blurb: "projects"
  },
  {
    name: "Blog",
    url: "/blog",
    blurb: "ramblings of a mad man"
  },
  {
    name: "Contact",
    url: "/contact",
    blurb: "carrier pigeon preferably"
  }
]
---

<Layout title="Cameron MacDonald" isHome currentPage="home">
  <div class="IndexWrap">
    <p class="Intro">Check out my stuff</p>
    <nav>
      {
        links.map((link) => {
          return (
            <a href={link.url} class="Card" id={link.name}>
              <h2>{link.name} <span class="material-symbols-rounded" aria-hidden="true">arrow_forward</span></h2>
              <p>{link.blurb}</p>
            </a>
          )
        })
      }
    </nav>
  </div>
</Layout>

<style lang="scss">
  @use "../../styles/_color.scss" as *;
  @use "../../styles/_breakpoints.scss" as *;
  @use "sass:color";

  .IndexWrap {
    width: 100%;
    nav {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr 1fr;
      gap: 1rem;

      @include mobile {
        grid-template-columns: 1fr;
      }
    }
  }

  .Intro {
    font-size: 2rem;
    @include mobile {
      font-size: 1.25rem;
      text-align: center;
      margin-top: 0;
    }
  }

  @mixin cardColor($color, $pos) {
    border: 3px solid $color;

    @media (pointer: fine) {
      &:hover,
      &:focus-visible {
        background-color: $color;
        z-index: 1;
  
        & > p {
          color: $black;
        }
      }

      @media (prefers-reduced-motion: no-preference) {
        transition: background-color 0.2s ease-in-out;
      }
    }

    &:focus {
      outline: 3px solid $color;
      outline-offset: 3px;
    }
  }

  a.Card {
    position: relative;
    container: card / inline-size;
    $padding-br: 3rem;
    $padding-tl: 1rem;
    border-radius: 10px;
    text-decoration: none;
    color: $off-white;
    padding: $padding-tl $padding-br $padding-br $padding-tl;
    display: block;
    transition: color 0.5s ease-in-out;
    height: 100%;

    @include mobile {
      padding-bottom: 2rem;
    }

    @media (pointer: fine) {
      &:hover,
      &:focus {
        color: $black;
      }
    }

    &#Resume {
      @include cardColor($off-white, 0);
    }
    &#Work {
      @include cardColor($orange-web, 1);
    }
    &#Blog {
      @include cardColor($pink-orange, 2);
    }
    &#Contact {
      @include cardColor($blue-light, 3);
    }
    & > h2 {
      display: flex;
      align-items: center;
      width: 100%;
      font-weight: 400;
      gap: 0.5rem;
      margin: 0;
      & > .material-symbols-rounded {
        height: 1em;
      }

      @include mobile {
        font-size: 1.25rem;
      }
    }

    & > p {
      color: transparent;
      transition: color 0.5s ease-in-out 0.1s;
      margin: 0;

      @media (pointer: coarse) {
        color: color.mix($black, $off-white, 50%);
      }

      @include mobile {
        font-size: 0.8rem;
      }
    }
  }
</style>
