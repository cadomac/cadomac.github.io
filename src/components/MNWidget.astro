<script>
    const modalButton = document.getElementById("sh-open-modal");
    const modal: HTMLDialogElement = document.querySelector(".sh-modal");
    const closeButton = modal.querySelector(".sh-close");

    function openModal() {
        modal.showModal();
        modalButton.setAttribute("aria-expanded", "true");
    }

    function closeModal() {
        console.log("close");
        modal.close();
        modalButton.setAttribute("aria-expanded", "false");
    }

    function handleModalClick(event: MouseEvent) {
        const rect = modal.getBoundingClientRect();
        const isInDialog =
            rect.top <= event.clientY &&
            event.clientY <= rect.top + rect.height &&
            rect.left <= event.clientX &&
            event.clientX <= rect.left + rect.width;
        if (!isInDialog) {
            modal.close();
        }
    }

    const modalTabbable: NodeListOf<HTMLElement> = modal.querySelectorAll(
        'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])',
    );

    function handleKeyDown(event: KeyboardEvent) {
        const { target } = event;
        if (event.key === "Tab") {
            if (
                target === modalTabbable[modalTabbable.length - 1] &&
                !event.shiftKey
            ) {
                event.preventDefault();
                modalTabbable[0].focus();
            } else if (target === modalTabbable[0] && event.shiftKey) {
                event.preventDefault();
                modalTabbable[modalTabbable.length - 1].focus();
            }
        }
    }

    modalButton.addEventListener("click", openModal);
    modal.addEventListener("keydown", handleKeyDown);
    modal.addEventListener("click", handleModalClick);
    closeButton.addEventListener("click", closeModal);
</script>

<style>
    #still-here-widget {
        --sh-night-sky: #002d5d;
        --sh-water: #52c9e8;
        --sh-white: #ffffff;
        --sh-surface: var(--sh-night-sky);
        --sh-accent: var(--sh-water);
        --sh-text: var(--sh-white);
    }
    .sh-fab-wrapper {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 2147483647;
        display: flex;
        flex-direction: column;
        align-items: flex-end;

        @media (max-width: 480px) {
            bottom: 4px;
            right: 50%;
            transform: translateX(50%);
        }
    }
    .sh-fab {
        border-radius: 9999px;
        padding: 0 8px 0 20px;
        height: 52px;
        gap: 10px;
        background: var(--sh-accent);
        color: var(--sh-night-sky);
        border: none;
        cursor: pointer;
