---
import Nav from './Nav.astro';

export interface Props {
  isHome?: boolean,
  currentPage: string
}

const { isHome=false, currentPage } = Astro.props;
---

<header>
  <a href="/"><h1>Cameron MacDonald</h1></a>
  <div class="NavWrap">
    {
      !isHome && <Nav currentPage={currentPage} />
    }
  </div>
</header>

<style lang="scss">
  @use "../../styles/_color.scss" as *;
  @use "../../styles/_breakpoints.scss" as *;
  @use "sass:color";
  body {
    & > header {
			display: flex;
			align-items: center;
			gap: 2rem;
			position: sticky;
      margin-top: 20px;
      margin-left: auto;
      margin-right: auto;
      top: 0;
			width: 100%;

      max-width: min(1345px, 100%);

      @include mobile {
        justify-content: center;
        gap: 0;
        margin-top: 0;

        & > .NavWrap {
          display: none;
        }
      }
      & > a {
        text-decoration: none;
      }
      $gradient-mix: color.mix($rose-pink, $orange, 50%);
      $background-gradient: linear-gradient(90deg, $rose-pink, $gradient-mix, $rose-pink);
			& > a > h1 {
				background: $background-gradient;
				background-size: 400% 100%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				font-weight: 800;
				padding: 1rem 2rem 1rem 2rem;

				margin: 0;

        &:hover {
          -webkit-background-clip: initial;
          -webkit-text-fill-color: $black;
          border-radius: 5px;
        }

				@media (prefers-reduced-motion: no-preference) {
					animation: headingBgSlide 15s ease-in-out infinite;
					transition: color 0.2s ease-in-out,
          -webkit-background-clip 0.4s ease-in-out,
          -webkit-text-fill-color 0.2s ease-in-out,
					background 0.2s ease-in-out;			
				}

        @include mobile {
          font-size: 1.5rem;
        }
			}

      & a:has(h1) {
        &:focus-visible,
        &:focus {
          outline-color: $gradient-mix;
          & h1 {
            -webkit-background-clip: initial;
            -webkit-text-fill-color: $black;
            border-radius: 5px;
          }
        }
      }
		}
  }

  @keyframes headingBgSlide {
		0% {
			background-position: 0% 50%;
		}

		100% {
			background-position: -400% 50%;
		}
	}
</style>